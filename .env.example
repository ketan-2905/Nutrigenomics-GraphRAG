```env
# Neo4j
NEO4J_URI=bolt://your-neo4j-host:7687
NEO4J_USERNAME=your_neo4j_username
NEO4J_PASSWORD=your_neo4j_password

# Chroma / Embeddings
CHROMA_PATH=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# OpenAI
OPENAI_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o-mini

# USDA FoodData Central
FDC_API_KEY=your_fdc_api_key
FDC_FOODS=food1,food2,food3,food4

# GWAS Catalog
GWAS_CATALOG_URL=https://your-gwas-catalog-download-url
GWAS_MAX_ROWS=5000

# NCBI / PubMed
NCBI_EMAIL=your_email@example.com
NCBI_API_KEY=your_ncbi_api_key
PUBMED_MAX_RESULTS=5

# Redis / Cache
REDIS_URL=redis://your-redis-host:6379/0
ENABLE_REDIS_CACHE=true
ENABLE_SEMANTIC_CACHE=true
CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_DISTANCE_THRESHOLD=0.12
CACHE_NAMESPACE=your_cache_namespace
DATASET_VERSION=v1
```
